# =====================================
#   General Text Normalization
# =====================================
# Force LF for all text files (cross-platform safe)
* text=auto eol=lf

# =====================================
#   Backend (Python + FastAPI)
# =====================================
*.py              text eol=lf
*.txt             text eol=lf
*.md              text eol=lf
*.toml            text eol=lf
*.yaml            text eol=lf
*.yml             text eol=lf
requirements.txt  text eol=lf

# =====================================
#   Frontend (React + Vite)
# =====================================
*.js              text eol=lf
*.jsx             text eol=lf
*.ts              text eol=lf
*.tsx             text eol=lf
*.css             text eol=lf
*.html            text eol=lf
*.json            text eol=lf

# =====================================
#   GeoJSON / GIS Files
# =====================================
# Prevent CRLF issues — geojson must stay LF only
*.geojson         text eol=lf
*.topojson        text eol=lf
*.map             text eol=lf

# =====================================
#   Jupyter Notebooks
# =====================================
*.ipynb           text eol=lf

# =====================================
#   Images / Binaries (never modify)
# =====================================
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.svg             text  # svg is XML, keep as text
*.pdf             binary

# =====================================
#   Database / Serialized Files
# =====================================
*.db              binary
*.sqlite          binary
*.pkl             binary
*.bin             binary

# =====================================
#   GitHub Linguist Overrides
# =====================================
# Make repo detected primarily as Python + AI/ML
*.py linguist-detectable=true
*.ipynb linguist-detectable=true
*.json linguist-vendored=false
*.yml linguist-vendored=false
*.yaml linguist-vendored=false

# Ignore build artifacts as "generated"
frontend/dist/*   linguist-generated=true
backend/__pycache__/* linguist-generated=true
